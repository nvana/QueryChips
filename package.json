{
  "name": "querychips",
  "version": "1.0.1",
  "description": "A modern, framework-agnostic JavaScript/TypeScript library for building intelligent filter UI components with smart input handling, keyboard navigation, and comprehensive accessibility features",
  "main": "dist/querychips.js",
  "module": "dist/querychips.mjs",
  "types": "dist/querychips.d.ts",
  "exports": {
    ".": {
      "types": "./dist/querychips.d.ts",
      "import": "./dist/querychips.mjs",
      "require": "./dist/querychips.js"
    },
    "./react": {
      "types": "./wrappers/QueryChipsReact.tsx",
      "import": "./wrappers/QueryChipsReact.tsx"
    },
    "./vue": {
      "types": "./wrappers/QueryChipsVue.vue",
      "import": "./wrappers/QueryChipsVue.vue"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "wrappers",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run clean && rollup -c && npm run build:css",
    "build:css": "node scripts/build-css.js",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "npm run test:coverage && npm run lint && npm run type-check",
    "lint": "eslint src wrappers --ext .ts,.js,.tsx,.vue",
    "lint:fix": "eslint src wrappers --ext .ts,.js,.tsx,.vue --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run test:ci && npm run build",
    "clean": "rimraf dist coverage",
    "prebuild": "npm run clean",
    "format": "prettier --write \"src/**/*.{ts,js,tsx}\" \"wrappers/**/*.{ts,tsx,vue}\" \"examples/**/*.{ts,js,tsx,vue,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,tsx}\" \"wrappers/**/*.{ts,tsx,vue}\" \"examples/**/*.{ts,js,tsx,vue,html}\"",
    "docs": "typedoc --out docs src/index.ts",
    "size": "npm run build && npx bundlephobia",
    "examples:react": "cd examples/react-example && npm run dev",
    "examples:vue": "cd examples/vue-example && npm run dev",
    "examples:elasticsearch": "cd examples/elasticsearch-example && npm run dev",
    "examples:vanilla": "cd examples/vanilla-example && npx http-server . -p 3000"
  },
  "keywords": [
    "querychips",
    "filter",
    "query",
    "ui",
    "typescript",
    "javascript",
    "framework-agnostic",
    "search",
    "tags",
    "dropdown",
    "keyboard-navigation",
    "accessible",
    "modern-ui",
    "elasticsearch",
    "sql",
    "mongodb",
    "graphql",
    "react",
    "vue",
    "angular",
    "data-filtering",
    "search-ui",
    "filter-component",
    "query-builder",
    "advanced-search"
  ],
  "author": {
    "name": "nvana",
    "url": "https://github.com/nvana"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nvana/querychips.git"
  },
  "bugs": {
    "url": "https://github.com/nvana/querychips/issues"
  },
  "homepage": "https://github.com/nvana/querychips#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.0.4",
    "jsdom": "^22.1.0",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.0",
    "rollup": "^3.28.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-typescript2": "^0.35.0",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.3.3"
  }
}
